# The published wire schema is generated by `python -m nvda_mcp_wire.schema`,
# which emits LF-terminated JSON. Pin it to LF in the working tree (the repo
# default is autocrlf=true) so the CI drift gate compares like against like on
# windows-latest instead of flagging pure line-ending churn.
specs/wire/v1/schema.json text eol=lf

# Same reasoning one layer up: wiregen writes LF, so its committed golden output
# is pinned to LF too. Without this the golden test compares LF against a
# CRLF checkout and fails on windows-latest over line endings alone.
server/tools/wiregen/testdata/* text eol=lf

# And the generated binding itself, for the same reason: `go generate` writes
# LF, so without this a regeneration leaves the working tree looking modified
# on a CRLF checkout even when nothing about the contract changed.
server/adapters/wire/*.gen.go text eol=lf
