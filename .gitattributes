# The published wire schema is generated by `python -m nvda_mcp_wire.schema`,
# which emits LF-terminated JSON. Pin it to LF in the working tree (the repo
# default is autocrlf=true) so the CI drift gate compares like against like on
# windows-latest instead of flagging pure line-ending churn.
specs/wire/v1/schema.json text eol=lf
